<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ChoiceBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="500.0" prefWidth="720.0" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.studentrecordmanagementsystem.Controller">
    <children>
        <VBox layoutX="20.0" layoutY="20.0" prefHeight="460.0" prefWidth="200.0" spacing="15.0">
            <children>
                <Label style="-fx-font-size: 16px; -fx-font-weight: bold;" text="Student Details" />
                <VBox spacing="5.0">
                    <children>
                        <Label text="Name:" />
                        <TextField fx:id="txtName" promptText="Enter full name" />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Course:" />
                        <TextField fx:id="txtCourse" promptText="Enter course" />
                    </children>
                </VBox>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Year Level:" />
                        <ChoiceBox fx:id="cbYear" prefWidth="200.0" />
                    </children>
                </VBox>
                <HBox spacing="10.0" style="-fx-padding: 10 0 0 0;">
                    <children>
                        <Button mnemonicParsing="false" onAction="#addStudent" prefWidth="95.0" style="-fx-background-color: #4CAF50; -fx-text-fill: white;" text="Add" />
                        <Button mnemonicParsing="false" onAction="#updateStudent" prefWidth="95.0" style="-fx-background-color: #2196F3; -fx-text-fill: white;" text="Update" />
                    </children>
                </HBox>
                <HBox spacing="10.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#deleteStudent" prefWidth="95.0" style="-fx-background-color: #f44336; -fx-text-fill: white;" text="Delete" />
                        <Button mnemonicParsing="false" onAction="#clearFields" prefWidth="95.0" style="-fx-background-color: #9e9e9e; -fx-text-fill: white;" text="Clear" />
                    </children>
                </HBox>
            </children>
        </VBox>
        <TableView fx:id="table" layoutX="240.0" layoutY="20.0" prefHeight="460.0" prefWidth="460.0">
            <columns>
                <TableColumn fx:id="colId" prefWidth="40.0" text="ID" />
                <TableColumn fx:id="colName" prefWidth="170.0" text="Name" />
                <TableColumn fx:id="colCourse" prefWidth="120.0" text="Course" />
                <TableColumn fx:id="colYear" prefWidth="128.0" text="Year Level" />
            </columns>
        </TableView>
    </children>
</AnchorPane>